.worktrees/
.audit-run/
.omc/
.swarm/
.venv-tools/
agentswarm/
.scratch/

# Node.js (added 2026-04-27 — stray npm artifacts; deps never tracked)
node_modules/

# chutes dispatch script (contains API key — never commit)
dispatch_chutes.py

