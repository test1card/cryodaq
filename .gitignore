config/*.local.yaml
config/*.local.yaml.yaml

# Claude Code — user-local state except skills which are shared
# repo-level agent behavior contract. Architect decision 2026-04-23:
# .claude/skills/ is versioned (auto-loading skills need to exist
# for every agent in the team, not just the user who created them).
# Other .claude/ paths (settings.local.json, hooks/, commands/,
# session state) remain user-local until a future policy decision.
#
# Pattern note: use .claude/* (content level) not .claude/ (dir
# level) so Git will descend into the directory and the negation
# below can re-include the skills/ subtree. With .claude/ as a
# whole-directory ignore, Git skips descent and !.claude/skills/
# has no effect.
.claude/*
!.claude/skills/

# OS
.DS_Store
Thumbs.db

# Test / coverage
.pytest_cache/
.coverage
htmlcov/

# Local audit artifacts (not committed)
DEEP_AUDIT_*.md
graphify-out/
graphify-out.stale-pre-merge/
logs/

# Runtime SQLite databases (per-machine, not portable).
# F-KnowledgeBaseExpansion (v0.55.7.1): the *contents* of data/ are
# ignored at the top level so nothing operator-machine-specific
# (SQLite WAL, agent cache, conductivity logs, parquet bursts) ever
# gets committed by accident. The knowledge subtree is the one
# carve-out — Markdown procedures, manuals, and operator-dropped PDFs
# travel with the repo so a fresh clone has the same RAG corpus the
# demo expects. The exclusion list (data/knowledge/**/*.lance,
# data/knowledge/**/*.cache) still blocks the LanceDB index + any
# embedding cache that could land here later.
data/*
!data/knowledge/
data/knowledge/**/*.lance
data/knowledge/**/*.cache

# Reference curves and predictor model — operator-supplied, not source-controlled
cooldown_v5/

# Agent orchestration workspaces (all untracked, gitignored per
# docs/ORCHESTRATION.md §6.4)
.worktrees/
.audit-run/
.omc/
.swarm/
.venv-tools/
agentswarm/
.scratch/

# Node.js (added 2026-04-27 — stray npm artifacts; deps never tracked)
node_modules/

# chutes dispatch script (contains API key — never commit)
dispatch_chutes.py
