# Локальная конфигурация приборов — СКОПИРУЙТЕ в instruments.local.yaml
# и отредактируйте адреса приборов для вашего стенда.
#
# Этот файл НЕ коммитится в git (*.local.yaml в .gitignore).
#
# ⚠️  ЗАМЕНА, НЕ СЛИЯНИЕ. Если instruments.local.yaml существует, engine
#     читает ТОЛЬКО его вместо instruments.yaml целиком (engine.py `_cfg`:
#     `return local if local.exists() else base`). Блоки НЕ мержатся.
#     Поэтому каждый top-level блок, который читает engine, должен быть
#     перенесён сюда, иначе он молча пропадёт:
#       - instruments        — список приборов (ниже)
#       - keithley.watchdog  — TSP late-pet check (иначе driver default off)
#       - chamber            — объём камеры + leak_rate (иначе volume_l пропадёт
#                              и оценка F13 leak rate отключится)
#     Значения keithley/chamber ниже — копия base-дефолтов из instruments.yaml;
#     правьте под стенд (volume_l ОБЯЗАТЕЛЬНО задать для leak rate).
#
# Адреса стенда АКЦ ФИАН (март 2026):
#   LS218_1: GPIB0::12  |  LS218_2: GPIB0::11 (poll 2.0s)
#   LS218_3: GPIB0::13  |  Keithley: USB0::0x05E6::0x2604::4083236
#   Thyracont: COM8, 115200

instruments:
  - type: lakeshore_218s
    name: "LS218_1"
    resource: "GPIB0::12::INSTR"
    poll_interval_s: 2.0
    channels:
      1: "Т1 Криостат верх"
      2: "Т2 Криостат низ"
      3: "Т3 Радиатор 1"
      4: "Т4 Радиатор 2"
      5: "Т5 Экран 77К"
      6: "Т6 Экран 4К"
      7: "Т7 Детектор"
      # 8: "Т8 Калибровка"  # раскомментировать если подключён

  - type: lakeshore_218s
    name: "LS218_2"
    resource: "GPIB0::11::INSTR"       # АКЦ ФИАН: GPIB0::11
    poll_interval_s: 2.0               # 2.0s для стабильности GPIB
    channels:
      1: "Т9 Компрессор вход"
      2: "Т10 Компрессор выход"
      3: "Т11 Теплообменник 1"
      4: "Т12 Теплообменник 2"
      5: "Т13 Труба подачи"
      6: "Т14 Труба возврата"
      7: "Т15 Вакуумный кожух"
      # 8: "Т16 Фланец"  # раскомментировать если подключён

  - type: lakeshore_218s
    name: "LS218_3"
    resource: "GPIB0::13::INSTR"       # АКЦ ФИАН: GPIB0::13
    poll_interval_s: 2.0
    channels:
      1: "Т17 Зеркало 1"
      2: "Т18 Зеркало 2"
      3: "Т19 Подвес"
      4: "Т20 Рама"
      # 5–8: резервные, раскомментировать по необходимости

  - type: keithley_2604b
    name: "Keithley_1"
    resource: "USB0::0x05E6::0x2604::4083236::INSTR"  # АКЦ ФИАН серийный
    poll_interval_s: 1.0

  - type: thyracont_vsp63d
    name: "VSP63D_1"
    resource: "COM8"                    # АКЦ ФИАН: COM8
    baudrate: 115200                    # АКЦ ФИАН: 115200
    poll_interval_s: 2.0

  # F-MultiLine Stage 1: Etalon MultiLine TCP/IP integration.
  # MultiLine.exe runs on a Windows PC; CryoDAQ engine connects as TCP client.
  # `host`: IP of the MultiLine PC, or "localhost" if same machine.
  # `port`: 2001 per Annex (04-2-Annex-MultiLine_as_server-Online-EN-20.pdf).
  # `channels`: list of channel numbers to query (typically [1, 2, 3, 4]).
  # Disable by removing this block until MultiLine PC is networked.
  - type: etalon_multiline
    name: "MultiLine_1"
    host: "192.168.1.50"                # MultiLine PC IP
    port: 2001
    channels: [1, 2, 3, 4]
    poll_interval_s: 2.0
    connect_timeout_s: 5.0
    read_timeout_s: 10.0

# ЗАМЕНА-семантика (см. шапку): блоки ниже перенесены из base instruments.yaml —
# без них engine потеряет watchdog и chamber, т.к. local НЕ мержится с base.

# Keithley 2604B TSP late-pet check под host SafetyManager. V3 неавтономен:
# best_effort покрывает только stall-then-recover, required fail-closed
# отказывает при autonomous=0. Полное описание — в base instruments.yaml.
keithley:
  watchdog:
    mode: "off"   # quote: bare off/on — YAML booleans
    # Finite numeric seconds in [1, 300]; use >= 2 * Keithley poll_interval_s.
    # os.time() is one-second-granularity and the deadline comparison is `>`.
    timeout_s: 5.0

chamber:
  volume_l: 0.0  # ОПЕРАТОР: задать реальный объём камеры в литрах (нужно для F13 leak rate)
  leak_rate:
    enabled: true
    default_sample_window_s: 300.0
