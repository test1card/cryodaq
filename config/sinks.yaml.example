# F31 — Sinks configuration. Copy to sinks.local.yaml and customize.
# `sinks.local.yaml` overrides this file; the local file is gitignored.

sinks:
  vault:
    enabled: false
    directory: "~/CryoDAQ-Vault/experiments"

  webhooks:
    # Example: AnythingLLM ingest endpoint
    - enabled: false
      url: "http://localhost:3001/api/v1/document/upload"
      timeout_s: 15.0
      verify_ssl: true
      extra_headers:
        Authorization: "Bearer YOUR_API_KEY"

    # Example: generic webhook
    - enabled: false
      url: "https://example.com/cryodaq/experiments"
      timeout_s: 10.0
      verify_ssl: true

  # F32 Stage 2 — rebuild the RAG knowledge-base index after each finalize.
  # Keys mirror SinkRegistry.load_config (registry.py). experiments_dir is
  # required; vault_dir / sqlite_path are optional (omit to skip that walker).
  rag_index:
    enabled: false
    rag_config_path: "config/rag.yaml"
    experiments_dir: "data/experiments"
    vault_dir: "~/CryoDAQ-Vault/experiments"  # optional
    sqlite_path: "data/cryodaq.db"            # optional
