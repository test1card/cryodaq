# Локальная конфигурация уведомлений — СКОПИРУЙТЕ в notifications.local.yaml
# и укажите ваш Telegram-токен и chat_id.
#
# Этот файл НЕ коммитится в git (*.local.yaml в .gitignore).

telegram:
  bot_token: "ВСТАВЬТЕ_ТОКЕН_ОТ_BOTFATHER"     # ← токен от @BotFather
  chat_id: 0                                     # ← ID чата (число)
  send_cleared: true
  timeout_s: 10
  # SECURITY (Phase 2b Codex K.1): if commands.enabled is true, this list
  # MUST contain at least one chat ID. Empty list + commands enabled is
  # treated as a config error and the bot refuses to start (default-deny).
  # Get your chat ID via @userinfobot on Telegram.
  allowed_chat_ids: []                            # ← [12345, 67890]

periodic_report:
  enabled: true
  report_interval_s: 1800                         # 30 минут
  chart_hours: 2.0
  include_channels: null

# SECURITY: keep commands.enabled: false until allowed_chat_ids above
# is populated with at least one trusted chat ID.
commands:
  enabled: false
  poll_interval_s: 2.0

# Цепочка эскалации при критических событиях (missed shift, emergency off)
# Каждый уровень — отдельный chat_id с задержкой.
escalation:
  - chat_id: 0                 # ← ночной оператор (немедленно)
    delay_minutes: 0
  - chat_id: 0                 # ← старший инженер (через 15 мин)
    delay_minutes: 15
  - chat_id: 0                 # ← руководитель (через 30 мин)
    delay_minutes: 30
